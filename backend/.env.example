# ─── moon.fun backend environment ────────────────────────────────────────────
# Copy to `.env` and fill in.

# ─── Server ──────────────────────────────────────────────────────────────────
BACKEND_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Database (Postgres 16) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://moon:moon@localhost:5432/moonfun

# ─── Redis (optional, for pub/sub fan-out) ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (for optional auth) ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── RPC URLs ────────────────────────────────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-arbitrum.api.onrender.com
ETHEREUM_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ─── Factory addresses (per chain) ───────────────────────────────────────────
FACTORY_BSC=
FACTORY_BASE=
FACTORY_ARBITRUM=
FACTORY_BSC_TESTNET=
FACTORY_BASE_SEPOLIA=
FACTORY_ARBITRUM_SEPOLIA=
FACTORY_ETHEREUM_SEPOLIA=

# ─── Wallet addresses (for fee routing metadata) ─────────────────────────────
TREASURY_ADDRESS=
DEV_WALLET_ADDRESS=
MOON_TOKEN=

# ─── Indexer ─────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=4000
START_BLOCK_OFFSET=10000
MAX_BLOCK_BATCH=500
