# ─── moon.fun backend environment ────────────────────────────────────────────
# Copy to `.env` and fill in.

# ─── Server ──────────────────────────────────────────────────────────────────
BACKEND_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL 16 (the only supported provider).
# Start the bundled instance with: docker compose up -d db
DATABASE_URL=postgresql://moon:moon@localhost:5432/moonfun

# ─── JWT (SIWE wallet auth) ──────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-char-min-secret-string

# ─── RPC URLs ────────────────────────────────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-arbitrum.api.onrender.com
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ─── Factory addresses (per chain) ───────────────────────────────────────────
FACTORY_BSC=
FACTORY_BASE=
FACTORY_ARBITRUM=
FACTORY_BSC_TESTNET=
FACTORY_BASE_SEPOLIA=
FACTORY_ARBITRUM_SEPOLIA=
FACTORY_ETHEREUM_SEPOLIA=

# ─── Wallet addresses (for fee routing metadata) ─────────────────────────────
TREASURY_ADDRESS=
DEV_WALLET_ADDRESS=
MOON_TOKEN=

# ─── Indexer ─────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=4000
START_BLOCK_OFFSET=10000
MAX_BLOCK_BATCH=500
# Block confirmations to lag behind chain head (reorg safety).
CONFIRMATIONS=12
# Blocks re-scanned each poll to heal shallow reorgs (<= CONFIRMATIONS).
REORG_REWIND_BLOCKS=12
