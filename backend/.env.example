# ─── Moon backend environment ────────────────────────────────────────────
# Copy to `.env` and fill in.

# ─── Server (BACKEND_ prefix) ────────────────────────────────────────────────
BACKEND_PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed to call the API + open Socket.io.
BACKEND_CORS_ORIGIN=http://localhost:5173

# ─── Database (DB_ prefix) ────────────────────────────────────────────────────
# PostgreSQL 16 (the only supported provider).
# Start the bundled instance with: docker compose up -d db
DB_URL=postgresql://moon:moon@localhost:5432/moon
DB_PROVIDER=postgresql

# ─── Auth (AUTH_ prefix) ──────────────────────────────────────────────────────
# JWT signing secret for SIWE wallet auth. Must be at least 32 characters.
# Generate with: openssl rand -hex 32
AUTH_JWT_SECRET=change-me-to-a-random-32-char-min-secret-string

# ─── Chain RPC URLs (CHAIN_ prefix) ───────────────────────────────────────────
CHAIN_BSC_RPC_URL=https://bsc-dataseed.binance.org
CHAIN_BASE_RPC_URL=https://mainnet.base.org
CHAIN_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
CHAIN_BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
CHAIN_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-arbitrum.api.onrender.com
CHAIN_ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ─── Chain factory addresses (CHAIN_ prefix, per chain) ───────────────────────
CHAIN_FACTORY_BSC=
CHAIN_FACTORY_BASE=
CHAIN_FACTORY_ARBITRUM=
CHAIN_FACTORY_BSC_TESTNET=
CHAIN_FACTORY_BASE_SEPOLIA=
CHAIN_FACTORY_ARBITRUM_SEPOLIA=
CHAIN_FACTORY_ETHEREUM_SEPOLIA=0xc08859b494eE018707CDCAD958d76A66B90b878d

# ─── Wallet addresses (WALLET_ prefix) ────────────────────────────────────────
# Used for fee-routing metadata on indexed events.
WALLET_TREASURY_ADDRESS=
WALLET_DEV_ADDRESS=
# $MOON governance token address (per active chain; only Eth Sepolia used today).
CHAIN_MOON_TOKEN_ETHEREUM_SEPOLIA=

# ─── Indexer (BACKEND_ prefix) ─────────────────────────────────────────────────
BACKEND_POLL_INTERVAL_MS=4000
BACKEND_START_BLOCK_OFFSET=10000
BACKEND_MAX_BLOCK_BATCH=500
# Block confirmations to lag behind chain head (reorg safety).
BACKEND_CONFIRMATIONS=12
# Blocks re-scanned each poll to heal shallow reorgs (<= BACKEND_CONFIRMATIONS).
BACKEND_REORG_REWIND_BLOCKS=12
