VITE_REFERRAL_REGISTRY_ARBITRUM=
VITE_MOON_BURNER_ARBITRUM=
VITE_V3_CONCENTRATOR_ARBITRUM=
VITE_MOON_TOKEN_ARBITRUM=

# BSC Testnet
