# ─── moon.fun frontend environment ───────────────────────────────────────────
# Copy to `.env` and fill in.
# Vite exposes only env vars with the FRONTEND_, CHAIN_, and E2E_ prefixes to the
# app (configured via `envPrefix` in vite.config.ts). Other layers (backend,
# contracts) use their own prefixes (BACKEND_*, DB_*, AUTH_*, WALLET_*, ...).

# ─── Frontend app config (FRONTEND_ prefix) ──────────────────────────────────
FRONTEND_API_URL=http://localhost:4000
FRONTEND_WALLETCONNECT_PROJECT_ID=

# ─── Default RPC fallbacks (per chain, CHAIN_ prefix) ─────────────────────────
CHAIN_BSC_RPC_URL=https://bsc-dataseed.binance.org
CHAIN_BASE_RPC_URL=https://mainnet.base.org
CHAIN_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
CHAIN_BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
CHAIN_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com
CHAIN_ETHEREUM_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ─── Contract addresses (7 chains × 7 contracts, CHAIN_ prefix) ──────────────
# BSC mainnet
CHAIN_FACTORY_BSC=
CHAIN_FEE_ROUTER_BSC=
CHAIN_CREATOR_FEE_VAULT_BSC=
CHAIN_REFERRAL_REGISTRY_BSC=
CHAIN_MOON_BURNER_BSC=
CHAIN_V3_CONCENTRATOR_BSC=
CHAIN_MOON_TOKEN_BSC=

# Base mainnet
CHAIN_FACTORY_BASE=
CHAIN_FEE_ROUTER_BASE=
CHAIN_CREATOR_FEE_VAULT_BASE=
CHAIN_REFERRAL_REGISTRY_BASE=
CHAIN_MOON_BURNER_BASE=
CHAIN_V3_CONCENTRATOR_BASE=
CHAIN_MOON_TOKEN_BASE=

# Arbitrum mainnet
CHAIN_FACTORY_ARBITRUM=
CHAIN_FEE_ROUTER_ARBITRUM=
CHAIN_CREATOR_FEE_VAULT_ARBITRUM=
CHAIN_REFERRAL_REGISTRY_ARBITRUM=
CHAIN_MOON_BURNER_ARBITRUM=
CHAIN_V3_CONCENTRATOR_ARBITRUM=
CHAIN_MOON_TOKEN_ARBITRUM=

# BSC Testnet
CHAIN_FACTORY_BSC_TESTNET=
CHAIN_FEE_ROUTER_BSC_TESTNET=
CHAIN_CREATOR_FEE_VAULT_BSC_TESTNET=
CHAIN_REFERRAL_REGISTRY_BSC_TESTNET=
CHAIN_MOON_BURNER_BSC_TESTNET=
CHAIN_V3_CONCENTRATOR_BSC_TESTNET=
CHAIN_MOON_TOKEN_BSC_TESTNET=

# Base Sepolia
CHAIN_FACTORY_BASE_SEPOLIA=
CHAIN_FEE_ROUTER_BASE_SEPOLIA=
CHAIN_CREATOR_FEE_VAULT_BASE_SEPOLIA=
CHAIN_REFERRAL_REGISTRY_BASE_SEPOLIA=
CHAIN_MOON_BURNER_BASE_SEPOLIA=
CHAIN_V3_CONCENTRATOR_BASE_SEPOLIA=
CHAIN_MOON_TOKEN_BASE_SEPOLIA=

# Arbitrum Sepolia
CHAIN_FACTORY_ARBITRUM_SEPOLIA=
CHAIN_FEE_ROUTER_ARBITRUM_SEPOLIA=
CHAIN_CREATOR_FEE_VAULT_ARBITRUM_SEPOLIA=
CHAIN_REFERRAL_REGISTRY_ARBITRUM_SEPOLIA=
CHAIN_MOON_BURNER_ARBITRUM_SEPOLIA=
CHAIN_V3_CONCENTRATOR_ARBITRUM_SEPOLIA=
CHAIN_MOON_TOKEN_ARBITRUM_SEPOLIA=

# Ethereum Sepolia
CHAIN_FACTORY_ETHEREUM_SEPOLIA=
CHAIN_FEE_ROUTER_ETHEREUM_SEPOLIA=
CHAIN_CREATOR_FEE_VAULT_ETHEREUM_SEPOLIA=
CHAIN_REFERRAL_REGISTRY_ETHEREUM_SEPOLIA=
