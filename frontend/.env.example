# ─── moon.fun frontend environment ───────────────────────────────────────────
# Copy to `.env` and fill in. Vite requires the VITE_ prefix.

# ─── API + WalletConnect ────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_WALLETCONNECT_PROJECT_ID=

# ─── Default RPC fallbacks (per chain) ───────────────────────────────────────
VITE_RPC_BSC=https://bsc-dataseed.binance.org
VITE_RPC_BASE=https://mainnet.base.org
VITE_RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
VITE_RPC_BSC_TESTNET=https://data-seed-prebsc-1-s1.binance.org:8545
VITE_RPC_BASE_SEPOLIA=https://sepolia.base.org
VITE_RPC_ARBITRUM_SEPOLIA=https://arbitrum-sepolia-rpc.publicnode.com
VITE_RPC_ETHEREUM_SEPOLIA=https://rpc.sepolia.org

# ─── Contract addresses (7 chains × 7 contracts) ────────────────────────────
# BSC mainnet
VITE_FACTORY_BSC=
VITE_FEE_ROUTER_BSC=
VITE_CREATOR_FEE_VAULT_BSC=
VITE_REFERRAL_REGISTRY_BSC=
VITE_MOON_BURNER_BSC=
VITE_V3_CONCENTRATOR_BSC=
VITE_MOON_TOKEN_BSC=

# Base mainnet
VITE_FACTORY_BASE=
VITE_FEE_ROUTER_BASE=
VITE_CREATOR_FEE_VAULT_BASE=
VITE_REFERRAL_REGISTRY_BASE=
VITE_MOON_BURNER_BASE=
VITE_V3_CONCENTRATOR_BASE=
VITE_MOON_TOKEN_BASE=

# Arbitrum mainnet
