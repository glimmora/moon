# ─────────────────────────  Build stage  ─────────────────────────
FROM node:20-slim AS build

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

WORKDIR /app

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY frontend/package.json ./frontend/
RUN pnpm install --frozen-lockfile --filter @Moon/frontend...

COPY frontend ./frontend

# FRONTEND_/CHAIN_/E2E_ vars are inlined at build time; pass with --build-arg if needed.
# Each chain has public fallback RPCs so these are all optional — but you
# should provide your own RPC endpoints and factory addresses in production.
ARG FRONTEND_API_URL
ARG CHAIN_BSC_RPC_URL
ARG CHAIN_BASE_RPC_URL
ARG CHAIN_ARBITRUM_RPC_URL
ARG CHAIN_ETHEREUM_SEPOLIA_RPC_URL
ARG CHAIN_BSC_TESTNET_RPC_URL
ARG CHAIN_BASE_SEPOLIA_RPC_URL
ARG CHAIN_ARBITRUM_SEPOLIA_RPC_URL
ARG CHAIN_FACTORY_BSC
ARG CHAIN_FACTORY_BASE
ARG CHAIN_FACTORY_ARBITRUM
ARG CHAIN_FACTORY_BSC_TESTNET
ARG CHAIN_FACTORY_BASE_SEPOLIA
ARG CHAIN_FACTORY_ARBITRUM_SEPOLIA
ARG CHAIN_FACTORY_ETHEREUM_SEPOLIA
ARG CHAIN_FEE_ROUTER_ETHEREUM_SEPOLIA
ARG CHAIN_CREATOR_FEE_VAULT_ETHEREUM_SEPOLIA
ARG CHAIN_REFERRAL_REGISTRY_ETHEREUM_SEPOLIA
ARG CHAIN_MOON_BURNER_ETHEREUM_SEPOLIA
ARG CHAIN_V3_CONCENTRATOR_ETHEREUM_SEPOLIA
ARG CHAIN_MOON_TOKEN_ETHEREUM_SEPOLIA
ARG FRONTEND_WALLETCONNECT_PROJECT_ID

# Propagate build-args so Vite can inline them via import.meta.env.
ENV FRONTEND_API_URL=${FRONTEND_API_URL}
ENV CHAIN_BSC_RPC_URL=${CHAIN_BSC_RPC_URL}
ENV CHAIN_BASE_RPC_URL=${CHAIN_BASE_RPC_URL}
ENV CHAIN_ARBITRUM_RPC_URL=${CHAIN_ARBITRUM_RPC_URL}
ENV CHAIN_ETHEREUM_SEPOLIA_RPC_URL=${CHAIN_ETHEREUM_SEPOLIA_RPC_URL}
ENV CHAIN_BSC_TESTNET_RPC_URL=${CHAIN_BSC_TESTNET_RPC_URL}
ENV CHAIN_BASE_SEPOLIA_RPC_URL=${CHAIN_BASE_SEPOLIA_RPC_URL}
ENV CHAIN_ARBITRUM_SEPOLIA_RPC_URL=${CHAIN_ARBITRUM_SEPOLIA_RPC_URL}
ENV CHAIN_FACTORY_BSC=${CHAIN_FACTORY_BSC}
ENV CHAIN_FACTORY_BASE=${CHAIN_FACTORY_BASE}
ENV CHAIN_FACTORY_ARBITRUM=${CHAIN_FACTORY_ARBITRUM}
ENV CHAIN_FACTORY_BSC_TESTNET=${CHAIN_FACTORY_BSC_TESTNET}
ENV CHAIN_FACTORY_BASE_SEPOLIA=${CHAIN_FACTORY_BASE_SEPOLIA}
ENV CHAIN_FACTORY_ARBITRUM_SEPOLIA=${CHAIN_FACTORY_ARBITRUM_SEPOLIA}
ENV CHAIN_FACTORY_ETHEREUM_SEPOLIA=${CHAIN_FACTORY_ETHEREUM_SEPOLIA}
ENV CHAIN_FEE_ROUTER_ETHEREUM_SEPOLIA=${CHAIN_FEE_ROUTER_ETHEREUM_SEPOLIA}
ENV CHAIN_CREATOR_FEE_VAULT_ETHEREUM_SEPOLIA=${CHAIN_CREATOR_FEE_VAULT_ETHEREUM_SEPOLIA}
ENV CHAIN_REFERRAL_REGISTRY_ETHEREUM_SEPOLIA=${CHAIN_REFERRAL_REGISTRY_ETHEREUM_SEPOLIA}
ENV CHAIN_MOON_BURNER_ETHEREUM_SEPOLIA=${CHAIN_MOON_BURNER_ETHEREUM_SEPOLIA}
ENV CHAIN_V3_CONCENTRATOR_ETHEREUM_SEPOLIA=${CHAIN_V3_CONCENTRATOR_ETHEREUM_SEPOLIA}
ENV CHAIN_MOON_TOKEN_ETHEREUM_SEPOLIA=${CHAIN_MOON_TOKEN_ETHEREUM_SEPOLIA}
ENV FRONTEND_WALLETCONNECT_PROJECT_ID=${FRONTEND_WALLETCONNECT_PROJECT_ID}
ENV NODE_ENV=production
RUN pnpm --filter @Moon/frontend run build

# ─────────────────────────  Runtime stage  ───────────────────────
FROM nginx:1.27-alpine AS runtime

# SPA routing: fall back to index.html for client-side routes.
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/frontend/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
